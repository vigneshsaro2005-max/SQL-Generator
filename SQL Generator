T\",\n","        \"email\": \"TEXT\",\n","        \"signup_date\": \"DATE\",\n","        \"age\": \"INTEGER\",\n","        \"country\": \"TEXT\",\n","        \"status\": \"TEXT\",\n","    },\n","    \"orders\": {\n","        \"id\": \"INTEGER PRIMARY KEY\",\n","        \"user_id\": \"INTEGER\",\n","        \"product_name\": \"TEXT\",\n","        \"amount\": \"REAL\",\n","        \"order_date\": \"DATE\",\n","        \"status\": \"TEXT\",\n","    },\n","    \"products\": {\n","        \"id\": \"INTEGER PRIMARY KEY\",\n","        \"name\": \"TEXT\",\n","        \"price\": \"REAL\",\n","        \"category\": \"TEXT\",\n","        \"stock\": \"INTEGER\",\n","    },\n","    \"transactions\": {\n","        \"id\": \"INTEGER PRIMARY KEY\",\n","        \"user_id\": \"INTEGER\",\n","        \"amount\": \"REAL\",\n","        \"date\": \"DATE\",\n","        \"type\": \"TEXT\",\n","    },\n","}\n","\n","# ============================================================================\n","# SECURITY\n","# ============================================================================\n","DANGEROUS_KEYWORDS = [\n","    \"DROP\",\n","    \"DELETE\",\n","    \"ALTER\",\n","    \"TRUNCATE\",\n","    \"INSERT\",\n","    \"UPDATE\",\n","    \"EXEC\",\n","    \"EXECUTE\",\n","]\n","\n","DANGEROUS_CHARS = [\";\", \"--\", \"/\", \"/\", \"xp_\", \"sp_\"]\n","\n","\n","def is_safe(text):\n","    \"\"\"Check if text contains dangerous SQL keywords\"\"\"\n","    text_upper = text.upper()\n","\n","    for keyword in DANGEROUS_KEYWORDS:\n","        if keyword in text_upper:\n","            return False\n","\n","    for char in DANGEROUS_CHARS:\n","        if char in text:\n","            return False\n","\n","    return True\n","\n","\n","# ============================================================================\n","# TABLE DETECTION\n","# ============================================================================\n","def get_table_name(query_text):\n","    \"\"\"Infer table name from natural language\"\"\"\n","    query_lower = query_text.lower()\n","\n","    keyword_map = {\n","        \"users\": [\"user\", \"users\", \"customer\", \"customers\", \"account\"],\n","        \"orders\": [\"order\", \"orders\", \"purchase\", \"buy\"],\n","        \"products\": [\"product\", \"products\", \"item\", \"goods\"],\n","        \"transactions\": [\"transaction\", \"transactions\", \"payment\"],\n","    }\n","\n","    for table, keywords in keyword_map.items():\n","        for keyword in keywords:\n","            if keyword in query_lower:\n","                return table\n","\n","    return \"users\"\n","\n","\n","# ============================================================================\n","# COLUMN DETECTION\n","# ============================================================================\n","def get_column_names(table_name, query_text):\n","    \"\"\"Map natural language to actual column names\"\"\"\n","    query_lower = query_text.lower()\n","    columns = list(SCHEMA[table_name].keys())\n","    selected_cols = []\n","\n","    column_map = {\n","        \"name\": [\"name\", \"username\"],\n","        \"email\": [\"email\", \"mail\"],\n","        \"signup_date\": [\"signup\", \"joined\", \"registered\", \"date\"],\n","        \"age\": [\"age\"],\n","        \"amount\": [\"amount\", \"price\", \"cost\"],\n","        \"date\": [\"date\"],\n","        \"status\": [\"status\", \"state\"],\n","        \"country\": [\"country\", \"location\"],\n","    }\n","\n","    for col, keywords in column_map.items():\n","        if col in columns:\n","            for keyword in keywords:\n","                if keyword in query_lower:\n","                    selected_cols.append(col)\n","                    break\n","\n","    if not selected_cols:\n","        selected_cols = [\"*\"]\n","\n","    return list(dict.fromkeys(selected_cols))\n","\n","\n","# ============================================================================\n","# CONDITION EXTRACTION\n","# ============================================================================\n","def extract_conditions(query_text):\n","    \"\"\"Extract WHERE conditions\"\"\"\n","    query_lower = query_text.lower()\n","    conditions = []\n","\n","    if \"last month\" in query_lower:\n","        conditions.append(\"DATE(signup_date) >= DATE('now','-1 month')\")\n","\n","    if \"last year\" in query_lower or \"this year\" in query_lower:\n","        conditions.append(\"DATE(signup_date) >= DATE('now','-1 year')\")\n","\n","    if \"last week\" in query_lower:\n","        conditions.append(\"DATE(signup_date) >= DATE('now','-7 days')\")\n","\n","    if \"today\" in query_lower:\n","        conditions.append(\"DATE(signup_date) = DATE('now')\")\n","\n","    if \"active\" in query_lower:\n","        conditions.append(\"status='active'\")\n","\n","    if \"inactive\" in query_lower:\n","        conditions.append(\"status='inactive'\")\n","\n","    amount_match = re.search(r\"(more than|above)\\s+([0-9]+)\", query_lower)\n","    if amount_match:\n","        conditions.append(f\"amount > {amount_match.group(2)}\")\n","\n","    amount_match = re.search(r\"(less than|below)\\s+([0-9]+)\", query_lower)\n","    if amount_match:\n","        conditions.append(f\"amount < {amount_match.group(2)}\")\n","\n","    return conditions\n","\n","\n","# ============================================================================\n","# SQL GENERATION\n","# ============================================================================\n","def generate_sql(query_text):\n","    \"\"\"Generate SQL from natural language\"\"\"\n","\n","    if not is_safe(query_text):\n","        return None, \"вќЊ Unsafe SQL detected!\"\n","\n","    table = get_table_name(query_text)\n","    columns = get_column_names(table, query_text)\n","\n","    columns_str = \", \".join(columns) if columns != [\"\"] else \"\"\n","\n","    sql = f\"SELECT {columns_str} FROM {table}\"\n","\n","    conditions = extract_conditions(query_text)\n","\n","    if conditions:\n","        sql += \" WHERE \" + \" AND \".join(conditions)\n","\n","    if \"all\" not in query_text.lower():\n","        sql += \" LIMIT 10\"\n","\n","    return sql, f\"Generated from table '{table}'\"\n","\n","\n","# ============================================================================\n","# QUERY PROCESSING\n","# ============================================================================\n","def process_query(user_query, chat_history):\n","    if not user_query.strip():\n","        return chat_history\n","\n","    chat_history.append((user_query, \"Processing...\"))\n","\n","    sql_query, explanation = generate_sql(user_query)\n","\n","    if sql_query is None:\n","        response = explanation\n","    else:\n","        response = f\"sql\\n{sql_query}\\n\\n\\n{explanation}\"\n","\n","        query_history.append(\n","            {\n","                \"user\": user_query,\n","                \"sql\": sql_query,\n","                \"timestamp\": datetime.now().isoformat(),\n","            }\n","        )\n","\n","    chat_history[-1] = (user_query, response)\n","\n","    return chat_history\n","\n","\n","# ============================================================================\n","# CLEAR CHAT\n","# ============================================================================\n","def clear_chat():\n","    global query_history\n","    query_history = []\n","    return []\n","\n","\n","# ============================================================================\n","# PDF EXPORT\n","# ============================================================================\n","def download_pdf():\n","\n","    if not query_history:\n","        return \"No queries!\", None\n","\n","    filename = f\"sql_queries_{datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf\"\n","\n","    styles = getSampleStyleSheet()\n","\n","    story = []\n","\n","    story.append(Paragraph(\"SQL Query Report\", styles[\"Heading1\"]))\n","    story.append(Spacer(1, 20))\n","\n","    for q in query_history:\n","        story.append(Paragraph(f\"User: {q['user']}\", styles[\"Normal\"]))\n","        story.append(Paragraph(f\"SQL: {q['sql']}\", styles[\"Code\"]))\n","        story.append(Spacer(1, 10))\n","\n","    doc = SimpleDocTemplate(filename, pagesize=letter)\n","    doc.build(story)\n","\n","    return \"PDF Generated\", filename\n","\n","\n","# ============================================================================\n","# TXT EXPORT\n","# ============================================================================\n","def download_txt():\n","\n","    if not query_history:\n","        return \"No queries!\", None\n","\n","    filename = f\"sql_queries_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt\"\n","\n","    content = \"\"\n","\n","    for q in query_history:\n","        content += f\"User: {q['user']}\\n\"\n","        content += f\"SQL: {q['sql']}\\n\\n\"\n","\n","    Path(filename).write_text(content)\n","\n","    return \"TXT Generated\", filename\n","\n","\n","# ============================================================================\n","# SHARE LINKS\n","# ============================================================================\n","def generate_whatsapp_link():\n","\n","    if not query_history:\n","        return \"No queries!\"\n","\n","    message = \"SQL Queries:\\n\\n\"\n","\n","    for q in query_history[-5:]:\n","        message += f\"{q['user']}\\n{q['sql']}\\n\\n\"\n","\n","    encoded = urllib.parse.quote(message)\n","\n","    return f\"https://wa.me/?text={encoded}\"\n","\n","\n","# ============================================================================\n","# UI\n","# ============================================================================\n","with gr.Blocks(title=\"SQL Query Generator\") as demo:\n","\n","    gr.Markdown(\"# SQL Query Generator\")\n","\n","    chatbot = gr.Chatbot(height=400)\n","\n","    query_input = gr.Textbox(\n","        placeholder=\"Show users who joined last month\",\n","        label=\"Enter Request\",\n","    )\n","\n","    send_btn = gr.Button(\"Generate SQL\")\n","\n","    send_btn.click(process_query, [query_input, chatbot], chatbot)\n","    query_input.submit(process_query, [query_input, chatbot], chatbot)\n","\n","    clear_btn = gr.Button(\"Clear\")\n","    clear_btn.click(clear_chat, outputs=[chatbot])\n","\n","    pdf_btn = gr.Button(\"Download PDF\")\n","    txt_btn = gr.Button(\"Download TXT\")\n","\n","    pdf_file = gr.File()\n","    txt_file = gr.File()\n","\n","    status = gr.Textbox()\n","\n","    pdf_btn.click(download_pdf, outputs=[status, pdf_file])\n","    txt_btn.click(download_txt, outputs=[status, txt_file])\n","\n","    share_btn = gr.Button(\"WhatsApp Share\")\n","    share_link = gr.Textbox()\n","\n","    share_btn.click(generate_whatsapp_link, outputs=share_link)\n","\n","demo.launch(share=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":680},"id":"X0XK3ewEm0jS","executionInfo":{"status":"ok","timestamp":1773127060599,"user_tz":-330,"elapsed":27208,"user":{"displayName":"Vignesh","userId":"15351192904981750630"}},"outputId":"d4762a66-574e-4a8b-ba98-8415cdb8f686"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_782/4064202961.py:320: UserWarning: You have not specified a value for the `type` parameter. Defaulting to the 'tuples' format for chatbot messages, but this is deprecated and will be removed in a future version of Gradio. Please set type='messages' instead, which uses openai-style dictionaries with 'role' and 'content' keys.\n","  chatbot = gr.Chatbot(height=400)\n","/tmp/ipykernel_782/4064202961.py:320: DeprecationWarning: The default value of 'allow_tags' in gr.Chatbot will be changed from False to True in Gradio 6.0. You will need to explicitly set allow_tags=False if you want to disable tags in your chatbot.\n","  chatbot = gr.Chatbot(height=400)\n"]},{"output_type":"stream","name":"stdout","text":["Colab notebook d